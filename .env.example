# Copy this file to .env and fill in real values. Never commit .env.

# --- Source Postgres (running on your laptop) ---
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=northwind_oltp
POSTGRES_USER=northwind_user
POSTGRES_PASSWORD=northwind_pass

# --- Snowflake ---
# Account identifier format examples:
#   abc12345.ap-south-1.aws    (region.cloud appended)
#   abc12345                   (legacy format, also works)
# Find yours in the Snowflake URL after login.
SNOWFLAKE_ACCOUNT=abc12345.ap-south-1.aws
SNOWFLAKE_USER=ETL_USER
SNOWFLAKE_PASSWORD=replace_with_strong_password
SNOWFLAKE_ROLE=ETL_ROLE
SNOWFLAKE_WAREHOUSE=ETL_WH
SNOWFLAKE_DATABASE=RETAIL_DB

# --- Airflow internals ---
AIRFLOW_UID=50000

# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=replace_with_generated_fernet_key
